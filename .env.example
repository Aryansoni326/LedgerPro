# ==========================================
# LedgerPro v2 Environment Variables
# ==========================================
# Local: copy to `.env`
# Vercel + Neon: see DEPLOYMENT.md
#   - .env.vercel.backend  (Django API)
#   - .env.vercel.frontend (Next.js)

# --- Django ---
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-for-prod
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_URL=http://localhost:3001

# --- Database (local Docker) ---
DB_NAME=ledgerpro_db
DB_USER=ledgerpro_user
DB_PASSWORD=ledgerpro_secure_password
DB_HOST=db
DB_PORT=5432
# Neon (production on Vercel API):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Redis (local only; Vercel uses CELERY_TASK_ALWAYS_EAGER) ---
REDIS_URL=redis://redis:6379/0

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- R2 (required for uploads on Vercel) ---
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=ledgerpro-vault
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=LedgerPro <your-email@gmail.com>

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
