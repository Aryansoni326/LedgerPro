# ==========================================
# LedgerPro v2 Environment Variables
# ==========================================

# --- Django Backend Configurations ---
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-for-prod
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Database Configurations (PostgreSQL) ---
DB_NAME=ledgerpro_db
DB_USER=ledgerpro_user
DB_PASSWORD=ledgerpro_secure_password
DB_HOST=db
DB_PORT=5432

# --- Redis & Celery Configurations ---
REDIS_URL=redis://redis:6379/0

# --- Google OAuth 2.0 ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized Redirect URIs must include: http://localhost:3001/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- AI / LLM API Key ---
GEMINI_API_KEY=your-gemini-api-key

# --- Cloudflare R2 Storage (S3-compatible) ---
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=ledgerpro-vault
CLOUDFLARE_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# --- Email / SMTP Configuration ---
# Example for Gmail (use an App Password, not your account password):
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=LedgerPro <your-email@gmail.com>

# --- Frontend Configurations ---
NEXT_PUBLIC_API_URL=http://localhost:8000
